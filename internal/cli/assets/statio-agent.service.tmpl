[Unit]
Description=statio deploy agent (tailnet-only)
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=notify
ExecStart=/usr/local/bin/statio agent run --config {{.ConfigPath}}
Restart=on-failure
RestartSec=2s
WatchdogSec=30s

# /run/statio is tmpfs (RAM): per-service compose + app env files live here so app secrets
# never touch persistent disk. Cleared on stop/reboot — a recreate then requires a redeploy.
RuntimeDirectory=statio
RuntimeDirectoryMode=0700

# /var/lib/statio (state: audience, audit log, tsnet). systemd creates it BEFORE setting up the
# mount namespace, so ProtectSystem=strict + ReadWritePaths below don't fail with 226/NAMESPACE
# when the dir doesn't pre-exist.
StateDirectory=statio
StateDirectoryMode=0700

# docker.sock is root-equivalent, so the agent runs as root; the compensating controls
# are cosign verify-before-act and this sandbox shrinking the agent's own attack surface.
NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/etc/statio /var/lib/statio /run/docker.sock /run/statio
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
# AF_INET/AF_INET6 (tailnet + GHCR + Cloudflare), AF_UNIX (docker.sock), and AF_NETLINK — Go's
# stdlib interface enumeration (net.Interfaces -> netlinkRIB), which tsnet calls during Up, opens an
# AF_NETLINK socket; without it tsnet.Up fails with
# "route ip+net: netlinkrib: address family not supported by protocol".
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6 AF_NETLINK
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
UMask=0077
CapabilityBoundingSet=
AmbientCapabilities=
# Do NOT add PrivateNetwork or IPAddressDeny — they break the tailnet listener and pulls.

[Install]
WantedBy=multi-user.target
