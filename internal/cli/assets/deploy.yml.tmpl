name: deploy
on:
  push:
    branches: [main]
  workflow_dispatch:
    inputs:
      digest:
        description: "Existing image digest to (re)deploy — use for rollback"
        required: false

# id-token: keyless cosign (OIDC); packages: push to GHCR; contents: checkout.
permissions:
  id-token: write
  packages: write
  contents: read

concurrency:
  group: deploy-${{ github.ref }}
  cancel-in-progress: false

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      # One step does it all: the statio action builds your image, pushes it to GHCR,
      # cosign-signs it (keyless), signs the deploy payload with the SAME identity, and
      # deploys it. No separate build-push or cosign steps to wire up.
      - uses: {{.ActionRef}}
        with:
          target: {{.Target}}
          service: {{.Service}}
          image: {{.Image}}
          # empty on push → the action builds & pushes; set on dispatch to redeploy/rollback.
          digest: ${{ inputs.digest }}
          ts-authkey: ${{ secrets.STATIO_TS_AUTHKEY }}
