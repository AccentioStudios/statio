# ── statio: one step builds, signs and deploys your image ──

# Your job needs these permissions (job or workflow level):
#      permissions:
#        id-token: write   # cosign keyless signing (image + deploy payload)
#        packages: write   # push the image to GHCR
#        contents: read

- uses: actions/checkout@v4
- uses: {{.ActionRef}}
  with:
    target:  {{.Target}}          # the agent (statio printed this on the server)
    service: {{.Service}}         # must be accepted on the server (statio app add)
    image:   {{.Image}}           # the action builds + pushes here; the agent runs it
    env: |                        # one KEY=${{ secrets.KEY }} per env your statio.yaml needs
      DATABASE_URL=${{ secrets.DATABASE_URL }}
    ts-authkey: ${{ secrets.STATIO_TS_AUTHKEY }}   # the auth key statio init server created

# Already build the image in your own step? Pass its digest and the action skips building
# (it still signs + deploys):  digest: ${{ steps.build.outputs.digest }}
# Sign it yourself too? Add:    sign: false
